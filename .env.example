# ——— Основной бот (заказы, уведомления) ———
BOT_TOKEN=
CHAT_ID=

# ——— Бот поддержки (отдельный процесс: npm run bot:support) ———
# Создайте бота в @BotFather, токен НЕ публикуйте и НЕ кладите в git.
SUPPORT_BOT_TOKEN=
# Ваш numeric Telegram user id (узнать: @userinfobot / @getidsbot)
ADMIN_ID=

# ——— Сборка frontend (Vite) ———
# @username бота поддержки БЕЗ https://, только имя, например: MyShopSupportBot
# Не токен; используется в ссылке https://t.me/MyShopSupportBot
VITE_SUPPORT_BOT_USERNAME=
